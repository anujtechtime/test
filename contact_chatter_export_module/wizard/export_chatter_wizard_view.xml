
<odoo>
    <record id="view_partner_chatter_export_wizard" model="ir.ui.view">
        <field name="name">partner.chatter.export.wizard.form</field>
        <field name="model">partner.chatter.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Chatter">
                <group>
                    <field name="partner_id"/>
                </group>
                <footer>
                    <button name="export_chatter"
                            string="Export"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
