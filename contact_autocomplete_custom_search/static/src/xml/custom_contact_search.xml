<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-extend="ControlPanel">

        <t t-jquery=".o_cp_searchview" t-operation="before">

            <t t-if="widget.modelName == 'res.partner'">

                <div class="o_contact_custom_search mr-2">

                    <input type="text"
                           class="form-control o_contact_search_input"
                           placeholder="Search Contact..."
                           autocomplete="off"/>

                </div>

            </t>

        </t>

    </t>

</templates>