<odoo>
    <template id="report_account_statement">
       <t t-call="web.external_layout">
          <!--<t t-foreach="docs" t-as="doc">-->
          <t t-set="level" t-value=""/>
            <div class="page">
                <main>
                <h2>كشف حساب / Account Statement</h2>
                
                <t t-if="docs.partner_id.level == 'leve1'">
                  <t t-set="level" t-value="' المرحلة الاولى '"/>
                </t>
                
                
                <t t-if="docs.partner_id.level == 'level2'">
                  <t t-set="level" t-value="'المرحلة الثانية'"/>
                </t>
                
                <t t-if="docs.partner_id.level == 'level3'">
                  <t t-set="level" t-value="'المرحلة الثالثة'"/>
                </t>
                
                
                <t t-if="docs.partner_id.level == 'level4'">
                  <t t-set="level" t-value="'المرحلة الرابعة'"/>
                </t>
                
                <t t-if="docs.partner_id.level == 'level5'">
                  <t t-set="level" t-value="'المرحلة الخامسة'"/>
                </t>
                
                
                
              

                <div class="col-12 text-center">
                  <strong>الطالبة:</strong><span t-esc="docs.partner_id.name"/>-<span t-esc="docs.partner_id.department.department"/>-<span t-esc="level"/>
                </div>
                
                <div class="row">
                  
                  <div class="col-6">
                
                <table class="table table-sm">
                    <thead>
                        <tr colspan="2">
                            <th>لفواتير كما تم تقسيمها</th>
                        </tr>
                        <tr>
                            <th>التاريخ</th>
                            <th>المبلغ</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="docs.env['account.move'].search([('partner_id','=',docs.partner_id.id),('type','=','out_invoice')], order='invoice_date_due asc')" t-as="inv">
                            <td><span t-esc="inv.invoice_date_due"/></td>
                            <td><span t-esc="inv.amount_total"/></td>
                        </tr>
                        <tr>
                          <td>المجموع</td>
                            <td><span t-esc="sum(docs.env['account.move'].search([('partner_id','=',docs.partner_id.id),('type','=','out_invoice')]).mapped('amount_total'))"/></td>
                        </tr>
                    </tbody>
                </table>
                </div>
                
                <div class="col-6">

                <table class="table table-sm">
                    <thead>
                      <tr colspan="2">
                            <th>الوصولات التي تم دفعها</th>
                        </tr>
                        <tr>
                            <th>تاريخ الوصل</th>
                            <th>المبلغ</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="docs.env['account.payment'].search([('partner_id','=',docs.partner_id.id)], order='payment_date asc')" t-as="pay">
                            <td><span t-esc="pay.payment_date"/></td>
                            <td><span t-esc="pay.amount"/></td>
                        </tr>
                        
                        <tr>
                            <td>المجموع</td>
                            <td> <span t-esc="sum(docs.env['account.payment'].search([('partner_id','=',docs.partner_id.id)]).mapped('amount'))"/></td>
                        </tr>
                    </tbody>
                </table>
                
                </div>
                </div>
                
                <div class="row">
                  <div class="col-12 text-left">
                  <strong>المدور</strong><t t-esc="sum(docs.env['account.move'].search([('partner_id','=',docs.partner_id.id),('type','=','out_invoice')]).mapped('amount_total')) - sum(docs.env['account.payment'].search([('partner_id','=',docs.partner_id.id)]).mapped('amount'))"/>
                </div>
                </div>
                </main>
            </div>
            <!--</t>-->
        </t>
    </template>
</odoo>
